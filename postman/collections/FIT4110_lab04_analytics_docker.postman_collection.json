    {
      "name": "02_Auth_Negative",
      "item": [
        {
          "name": "GET events without token returns 401",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/analytics/events"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Missing token returns 401', function () { pm.response.to.have.status(401); });",
                  "assertProblemDetails();",
                  "function assertProblemDetails() {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('type');",
                  "  pm.expect(json).to.have.property('title');",
                  "  pm.expect(json.status).to.eql(401);",
                  "  pm.expect(json).to.have.property('detail');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET events with wrong token returns 401",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer wrong-token" }
            ],
            "url": "{{baseUrl}}/analytics/events"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Wrong token returns 401', function () { pm.response.to.have.status(401); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.status).to.eql(401);",
                  "pm.expect(json).to.have.property('detail');"
                ]
              }
            }
          ]
        },
