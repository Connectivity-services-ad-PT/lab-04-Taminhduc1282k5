        {
          "name": "GET analytics events returns page",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/analytics/events"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is AnalyticsPage', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.items).to.be.an('array');",
                  "  pm.expect(json.total).to.be.a('number');",
                  "  pm.expect(json.page).to.eql(1);",
                  "  pm.expect(json.pageSize).to.eql(10);",
                  "});"
                ]
              }
            }
          ]
        },
        {
