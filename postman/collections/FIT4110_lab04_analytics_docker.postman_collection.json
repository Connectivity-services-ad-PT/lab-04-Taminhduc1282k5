        {
          "name": "GET known report returns 200",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/analytics/report/11111111-1111-4111-8111-111111111111"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is AnalyticsResult', function () { const json = pm.response.json(); pm.expect(json.analyticsId).to.eql('11111111-1111-4111-8111-111111111111'); pm.expect(json).to.have.property('generatedAt'); });"
                ]
              }
            }
          ]
        }
