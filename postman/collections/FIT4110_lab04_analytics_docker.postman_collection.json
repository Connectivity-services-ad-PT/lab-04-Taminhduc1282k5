{
  "info": {
    "name": "FIT4110 Lab04 Analytics Docker Verification",
    "description": "Verifies the Dockerized Smart Campus Analytics Service against the Lab 04 OpenAPI contract.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET health returns 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Health schema matches contract', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "  pm.expect(json.service).to.eql('analytics-service');",
                  "  pm.expect(json.time).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST IoT event returns 201",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/analytics/iot-events",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"SENSOR-001\",\n  \"metric\": \"temperature\",\n  \"value\": 38.5,\n  \"timestamp\": \"{{$isoTimestamp}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });"
                ]
              }
            }
          ]
        },
